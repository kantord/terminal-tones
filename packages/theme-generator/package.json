{
  "name": "@terminal-tones/theme-generator",
  "version": "0.1.0",
  "description": "Core theme generation logic for Terminal Tones",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@adobe/leonardo-contrast-colors": "^1.0.0",
    "colorthief": "2.6.0",
    "culori": "^4.0.1"
  },
  "devDependencies": {
    "@types/colorthief": "2.6.0",
    "@types/culori": "^4.0.0",
    "@types/node": "^24.1.0",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
}