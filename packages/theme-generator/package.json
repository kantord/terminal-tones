    "itertools": "^2.4.1",
    "munkres": "^2.0.4"
  },
  "devDependencies": {
    "@types/colorthief": "2.6.0",
    "@types/culori": "^4.0.0",
    "@types/node": "^24.1.0",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
