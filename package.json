{
  "name": "@terminal-tones/monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "e2e": "pnpm --filter web e2e",
    "e2e:run": "pnpm --filter web e2e:run",
    "build": "pnpm --filter theme-generator build && pnpm --filter web build",
    "build:theme": "pnpm --filter theme-generator build",
    "start": "pnpm --filter web start",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^26.1.0",
    "prettier": "3.6.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    
  }
}
